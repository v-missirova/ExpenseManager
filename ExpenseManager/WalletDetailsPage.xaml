<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             xmlns:models="clr-namespace:ExpenseManager.DBModels;assembly=ExpenseManager.DBModels"
             x:Class="MauiApp1.WalletDetailsPage"
             Title="Transactions">

    <Grid>
        <Grid RowDefinitions="Auto, *" Padding="20">

            <Label Grid.Row="0"
                   Text="History:" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   Margin="0,0,0,10" />

            <CollectionView Grid.Row="1" 
                            x:Name="TransactionsCollection"
                            ItemsSource="{Binding Transactions}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TransactionDBModel">
                        <Border Stroke="DimGray"
                                StrokeShape="RoundRectangle 15"
                                Padding="12"
                                BackgroundColor="#1E1E1E">

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="{Binding Category}" FontAttributes="Bold" FontSize="16" TextColor="White"/>
                                        <Label Grid.Column="1" Text="{Binding DateTimeOfTransaction, StringFormat='{0:dd.MM HH:mm}'}" FontSize="12" TextColor="Gray" VerticalOptions="Center"/>
                                    </Grid>

                                    <Label Text="{Binding Description}" FontSize="14" TextColor="LightGray" Margin="0,2,0,5"/>

                                    <Label Text="{Binding Amount, StringFormat='{0:F2}'}" 
                                           FontSize="18" 
                                           FontAttributes="Bold" 
                                           TextColor="White" />
                                </VerticalStackLayout>

                                <ImageButton Grid.Column="1" 
                                             Source="dotnet_bot.png" 
                                             WidthRequest="30" HeightRequest="30"
                                             BackgroundColor="Transparent"
                                             VerticalOptions="Center"
                                             Command="{Binding Source={x:Reference TransactionsCollection}, Path=BindingContext.DeleteTransactionCommand}"
                                             CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50,0,0">
                        <Label Text="No transactions yet..." TextColor="Gray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <Grid BackgroundColor="#80000000" IsVisible="{Binding IsBusy}" ZIndex="999">
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="60" HeightRequest="60" />
        </Grid>
    </Grid>
</ContentPage>