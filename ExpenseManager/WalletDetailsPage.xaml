<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             xmlns:models="clr-namespace:ExpenseManager.DBModels;assembly=ExpenseManager.DBModels"
             x:Class="MauiApp1.WalletDetailsPage"
             Title="Wallet details :0 >:)">

    <Grid>
        <Grid RowDefinitions="Auto, Auto, Auto, *" Margin="20">

            <Border Grid.Row="0"
                    Stroke="LightGray"
                    StrokeShape="RoundRectangle 35, 35, 35, 35"
                    Padding="15"
                    Margin="0,0,0,10"
                    Background="#dbdbdb">
                <VerticalStackLayout>
                    <Label Text="{Binding WalletName}" FontSize="22" FontAttributes="Bold" TextColor="#2B0B98"/>
                    <Label Text="{Binding WalletCurrency, StringFormat='Currency: {0}'}" FontSize="16" TextColor="#9d9d9d" />
                    <Label Text="{Binding WalletBalance, StringFormat='Balance: {0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="DarkGreen" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>

            <Button Grid.Row="1"
                    Text="Add Transaction"
                    Command="{Binding ToggleAddFormCommand}"
                    BackgroundColor="#2B0B98"
                    TextColor="White"
                    CornerRadius="20"
                    Margin="0,0,0,10" />

            <Border Grid.Row="2" 
                    IsVisible="{Binding IsAddFormVisible}"
                    Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 35, 35, 35, 35"
                    Padding="20" 
                    Margin="0,0,0,20" 
                    Background="#F2F2F2">
                <VerticalStackLayout Spacing="10">
                    <Label Text="New Transaction" FontSize="18" FontAttributes="Bold" TextColor="#2B0B98" HorizontalOptions="Center"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Entry Grid.Column="0" 
                               Placeholder="Sum" 
                               Text="{Binding NewTransactionAmount}" 
                               Keyboard="Numeric"
                               TextColor="Black"
                               PlaceholderColor="Gray"/>

                        <Picker Grid.Column="1" 
                                Title="Category" 
                                ItemsSource="{Binding Categories}" 
                                SelectedItem="{Binding NewTransactionCategory}"
                                TextColor="Black" TitleColor="Gray"/>
                    </Grid>

                    <Entry Placeholder="Description" 
                           Text="{Binding NewTransactionDescription}" 
                           TextColor="Black"
                           PlaceholderColor="Gray"/>

                    <Button Text="Save" 
                            Command="{Binding AddTransactionCommand}" 
                            BackgroundColor="#2B0B98" 
                            TextColor="White" 
                            CornerRadius="20"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <CollectionView Grid.Row="3" 
                            x:Name="TransactionsCollection"
                            ItemsSource="{Binding Transactions}"
                            SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                            SelectionMode="Single">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TransactionDBModel">
                        <Border Margin="0,0,0,10" 
                                Padding="15" 
                                Stroke="#E0E0E0" 
                                StrokeShape="RoundRectangle 35, 35, 35, 35"
                                BackgroundColor="#dbdbdb">
                            <Grid ColumnDefinitions="*, Auto, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="10">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Category}" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding Description}" FontSize="14" TextColor="#404040"/>

                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Amount, StringFormat='{0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="Black" HorizontalOptions="End"/>
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding DateTimeOfTransaction, StringFormat='{0:dd.MM.yyyy}'}" FontSize="12" TextColor="Gray" HorizontalOptions="End"/>

                                <ImageButton Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                             Source="dotnet_bot.png" 
                                             WidthRequest="25" HeightRequest="25"
                                             BackgroundColor="Transparent"
                                             VerticalOptions="Center"
                                             Command="{Binding Source={x:Reference TransactionsCollection}, Path=BindingContext.DeleteTransactionCommand}"
                                             CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid BackgroundColor="#80000000" IsVisible="{Binding IsBusy}" ZIndex="999">
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="60" HeightRequest="60" />
        </Grid>
    </Grid>
</ContentPage>